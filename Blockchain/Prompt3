## On-chain contract: `TradingSC.sol` (minimal, gas-efficient)

Save as `contracts/TradingSC.sol`. Comments included.

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.27;

import "@openzeppelin/contracts/utils/cryptography/ECDSA.sol";

contract TradingSC {
    using ECDSA for bytes32;

    // compact commit struct (keeps storage minimal)
    struct Commit {
        address owner;      // signer address (from IdentitySC)
        uint32 roundId;     // fits in 32 bits
        uint32 expiryBlock; // fits in 32 bits
        bool revealed;      // 1 byte
        // commitHash is used as mapping key (keccak256(offerHash | salt))
    }

    // commitHash => Commit
    mapping(bytes32 => Commit) public commits;

    // event
    event CommitPosted(bytes32 indexed commitHash, address indexed owner, uint32 roundId, uint32 expiryBlock);
    event OfferRevealed(bytes32 indexed commitHash, bytes32 offerHash, bytes saltHash); // saltHash optional for audit

    // post a commit on chain
    // sig = signature of offerHash (EIP-191/EIP-712) or offer author signature
    function postCommit(bytes32 commitHash, bytes32 offerHash, uint32 roundId, uint32 expiryBlock, bytes calldata sig) external {
        require(commits[commitHash].owner == address(0), "commit exists");

        // recover signer from offerHash signature
        address signer = _recoverSigner(offerHash, sig);
        require(signer != address(0), "invalid sig");

        // save commit; owner = signer
        commits[commitHash] = Commit({owner: signer, roundId: roundId, expiryBlock: expiryBlock, revealed: false});
        emit CommitPosted(commitHash, signer, roundId, expiryBlock);
    }

    // reveal: provide offerHash and salt, verify keccak(offerHash | salt) == commitHash
    // optional: saltHash to avoid revealing raw salt on-chain (but on reveal you must reveal salt)
    function revealOffer(bytes32 commitHash, bytes32 offerHash, bytes calldata salt) external {
        Commit storage c = commits[commitHash];
        require(c.owner != address(0), "no commit");
        require(!c.revealed, "already revealed");
        require(block.number <= c.expiryBlock, "commit expired for reveal");

        // verify commit integrity
        bytes32 computed = keccak256(abi.encodePacked(offerHash, salt));
        require(computed == commitHash, "mismatch commit");

        // optional: verify offerHash signer again? skip since postCommit checked signature
        // mark revealed
        c.revealed = true;

        emit OfferRevealed(commitHash, offerHash, keccak256(salt));
    }

    // helper to recover signer from offerHash signature (ECDSA)
    function _recoverSigner(bytes32 offerHash, bytes memory sig) internal pure returns (address) {
        // assume offerHash is the keccak256 of ABI-encoded offer struct; standardized signing (EIP-191) may be used
        // Best: use EIP-712 domain outside; here we'll treat offerHash as already domain-separated
        return ECDSA.recover(offerHash, sig);
    }

    // view helpers
    function isCommitRevealed(bytes32 commitHash) external view returns (bool) {
        return commits[commitHash].revealed;
    }
}
```

**Notes / improvements**

* For EIP-712, you may prefer to recover signer using `_hashTypedDataV4` in a more complete contract (requires EIP-712 implementation). The example above assumes `offerHash` is the domain-separated hash returned by the Pi signer.
* To save gas, commit is keyed by `commitHash` (32 bytes) and stores only the minimal metadata.

