## Pi client flow & example scripts (Node.js)

Create `pi-client/compose_offer.js` — deterministic composition & hashing:

```js
// compose_offer.js
const ethers = require('ethers');

// quantization map is project-specific; keep it small
function composeOffer(roundId, nodeIdHex, kwhBucket, priceBucket, nonce, expiryBlock) {
  // pack values same way Solidity does: abi.encodePacked
  const abi = ethers.utils.defaultAbiCoder;
  const packed = ethers.utils.solidityPack(
    ['uint32','bytes32','uint16','uint16','uint32','uint32'],
    [roundId, nodeIdHex, kwhBucket, priceBucket, nonce, expiryBlock]
  );
  const offerHash = ethers.utils.keccak256(packed);
  return { packed, offerHash };
}
module.exports = { composeOffer };
```

Create `pi-client/sign_offer.js` — EIP-712 typed signing or sign `offerHash` directly:

```js
// sign_offer.js
const { ethers } = require('ethers');
async function signOfferHash(wallet, offerHash) {
  // OPTION A: if wallet._signTypedData used, compute typedData domain & types
  // Simpler: sign the 32-byte offerHash directly (ensure domain separation in production)
  const sig = await wallet.signMessage(ethers.utils.arrayify(offerHash)); // EIP-191
  return sig;
}
module.exports = { signOfferHash };
```

