{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Hardhat Node",
      "type": "shell",
      "command": "npx hardhat node",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Compile Contracts",
      "type": "shell",
      "command": "npx hardhat compile",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Deploy IdentitySC (localhost)",
      "type": "shell",
      "command": "npx hardhat run scripts/deploy.js --network localhost",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "dependsOn": "Compile Contracts"
    },
    {
      "label": "Run Unit Tests",
      "type": "shell",
      "command": "npx hardhat test",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run Integration Test",
      "type": "shell",
      "command": "node scripts/integration/registerFlow.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": []
    },
    {
      "label": "Start Relayer",
      "type": "shell",
      "command": "node relayer/server.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Off-Chain Registry",
      "type": "shell",
      "command": "node offchain-registry/server.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Up",
      "type": "shell",
      "command": "docker compose up -d",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Down",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": []
    },
    {
      "label": "Pi: Generate Keys",
      "type": "shell",
      "command": "node generate_keys.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain/pi-client" },
      "problemMatcher": []
    },
    {
      "label": "Pi: Register via Relayer",
      "type": "shell",
      "command": "node register_via_relayer.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain/pi-client" },
      "problemMatcher": []
    },
    {
      "label": "Pi: Device Attestation",
      "type": "shell",
      "command": "node device_attestation.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain/pi-client" },
      "problemMatcher": []
    },
    {
      "label": "Deploy CollateralSC (localhost)",
      "type": "shell",
      "command": "npx hardhat run scripts/deploy_collateral.js --network localhost",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "dependsOn": "Compile Contracts"
    },
    {
      "label": "Run Gas Flow Integration Test",
      "type": "shell",
      "command": "node scripts/integration/gasFlow.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": []
    },
    {
      "label": "Pi: Sign Gas Voucher",
      "type": "shell",
      "command": "node sign_gas_voucher.js --txHash 0x --gasUsed 50000 --gasPrice 1000000000 --relayer 0x",
      "options": { "cwd": "${workspaceFolder}/Blockchain/pi-client" },
      "problemMatcher": []
    },
    {
      "label": "Pi: Request Meta-Tx",
      "type": "shell",
      "command": "node request_meta_tx.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain/pi-client" },
      "problemMatcher": []
    },
    {
      "label": "Deploy TradingSC (localhost)",
      "type": "shell",
      "command": "npx hardhat run scripts/deploy_trading.js --network localhost",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "dependsOn": "Compile Contracts"
    },
    {
      "label": "Run Trading Tests",
      "type": "shell",
      "command": "npx hardhat test tests/trading.test.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run Commit-Reveal Integration Test",
      "type": "shell",
      "command": "node scripts/integration/simulate_pi_commit_reveal.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": []
    },
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "npx hardhat test",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Deploy MatchRegistry (localhost)",
      "type": "shell",
      "command": "npx hardhat run scripts/deploy_matchregistry.js --network localhost",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "dependsOn": "Compile Contracts"
    },
    {
      "label": "Run Match Registry Tests",
      "type": "shell",
      "command": "npx hardhat test tests/matchregistry.test.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run Match Flow Integration Test",
      "type": "shell",
      "command": "node scripts/integration/match_flow.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "problemMatcher": []
    },
    {
      "label": "Start Indexer",
      "type": "shell",
      "command": "node indexer/indexer.js",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Adjudicator (mock)",
      "type": "shell",
      "command": "node adjudicator/mock_adjudicator.js --policy accept",
      "options": { "cwd": "${workspaceFolder}/Blockchain" },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
