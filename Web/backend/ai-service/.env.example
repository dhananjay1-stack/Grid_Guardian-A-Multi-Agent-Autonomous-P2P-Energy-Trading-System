# Grid-Guardian AI Decision Engine Configuration

# Server settings
AI_SERVER_HOST=0.0.0.0
AI_SERVER_PORT=5050
AI_SERVER_DEBUG=false
AI_SERVER_WORKERS=1

# Model paths (relative to project root)
# MODEL_BASE_PATH=../../Agentic_AI/models
# POLICY_PACK_PATH=../../Agentic_AI/edge/policy_pack

# Default policy selection
DEFAULT_POLICY=DT
FALLBACK_POLICY=BC

# Use ONNX Runtime instead of TorchScript
USE_ONNX_RUNTIME=false

# Logging
LOG_LEVEL=INFO
