# Grid-Guardian Edge Configuration for Raspberry Pi
# Copy this file to your Raspberry Pi: grid_guardian_edge/.env

# =============================================================================
#                           NODE IDENTITY
# =============================================================================
# Give your Pi a unique ID - this appears in the dashboard
NODE_ID=pi-hardware-01
NODE_TYPE=prosumer

# =============================================================================
#                           BACKEND CONNECTION
# =============================================================================
# Change this to your laptop's IP address (run 'ipconfig' on Windows to find it)
# Example: If your laptop is 192.168.1.100, use that
BACKEND_URL=http://YOUR_LAPTOP_IP:3000

# =============================================================================
#                           MQTT SETTINGS
# =============================================================================
# MQTT broker on your laptop (optional, can disable if not using)
MQTT_ENABLED=false
MQTT_BROKER=YOUR_LAPTOP_IP
MQTT_PORT=1883

# =============================================================================
#                           HARDWARE SETTINGS
# =============================================================================
# Serial port for PZEM-004T energy meter
SERIAL_PORT=/dev/serial0
BAUD_RATE=9600

# GPIO pin for relay module (BCM numbering)
RELAY_PIN=17
RELAY_ACTIVE_HIGH=true

# =============================================================================
#                           RUNTIME SETTINGS
# =============================================================================
# How often to read sensors and send data (seconds)
LOOP_INTERVAL=5.0

# =============================================================================
#                           SAFETY SETTINGS
# =============================================================================
SAFE_MODE_ENABLED=true
MAX_VOLTAGE=260.0
MIN_VOLTAGE=180.0
MAX_CURRENT=30.0
MAX_POWER=6000.0

# =============================================================================
#                           LOGGING
# =============================================================================
LOG_LEVEL=INFO
